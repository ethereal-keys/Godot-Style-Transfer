from SCons.Script import Exit

print("SCons is no longer the supported build path for ArtSyn_extension.")
print("Use CMake instead.")
print("Example:")
print("  cmake -S ArtSyn_extension -B build \\")
print("    -DGODOT_CPP_DIR=/path/to/godot-cpp \\")
print("    -DGODOT_CPP_LIBRARY=/path/to/libgodot-cpp.linux.template_debug.x86_64.a \\")
print("    -DCMAKE_PREFIX_PATH=/path/to/libtorch")
print("  cmake --build build")

Exit(1)
